{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=YOUR_DB_NAME;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD"
  },
  "Jwt": {
    "Key": "YOUR_JWT_SIGNING_KEY_MIN_32_CHARS",
    "Issuer": "keep-whatever-your-real-issuer-is",
    "Audience": "keep-whatever-your-real-audience-is"
  },
  "Resend": {
    "ApiKey": "YOUR_RESEND_API_KEY"
  }
}